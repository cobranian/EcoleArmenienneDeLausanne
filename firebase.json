{
  "hosting": {
    "target": "ecole",
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".firebase/**",
      "**/.*",
      "**/node_modules/**",
      "School-text.txt",
      "**/*.md",
      "**/*Name clash*"
    ],
    "headers": [
      {
        "source": "**/*.@(jpg|jpeg|png|webp|svg|ico)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=604800, immutable" }
        ]
      },
      {
        "source": "/index.html",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=300" }
        ]
      }
    ],
    "cleanUrls": true,
    "trailingSlash": false
  }
}
